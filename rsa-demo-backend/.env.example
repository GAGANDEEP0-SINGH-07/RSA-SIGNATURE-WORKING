PORT=5000
MONGO_URI=mongodb://localhost:27017/rsa-demo
JWT_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_STRING_AT_LEAST_32_CHARS
JWT_EXPIRES_IN=7d
NODE_ENV=development
BCRYPT_ROUNDS=10
RSA_KEY_SIZE=2048

# ── Google OAuth ──
GOOGLE_CLIENT_ID=your_google_client_id_here

# ── Frontend URL (for password reset emails) ──
FRONTEND_URL=http://localhost:5173

# ── SMTP Configuration (Gmail App Password) ──
# To get a Gmail App Password:
#   1. Enable 2-Step Verification on your Google Account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Generate a new App Password for "Mail"
#   4. Paste the 16-character password below
#
# If these are left empty, password reset tokens will be
# logged to the console instead of emailed (dev mode).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM="RSA Secure Chat <your_email@gmail.com>"
